{
    "name": "Gleam (via GitHub Releases)",
    "id": "gleam",
    "version": "0.1.0",
    "description": "Gleam is a friendly language for building type-safe systems that scale!",
    "documentationURL": "https://github.com/NicoVIII/devcontainer-features/tree/main/src/gleam",
    "options": {
        "version": {
            "type": "string",
            "description": "The version of Gleam to install. Use 'latest' to install the latest version.",
            "proposals": [
                "latest",
                "1.52.2"
            ],
            "default": "latest"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "gleam.gleam"
            ]
        }
    }
}
