{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Check",
            "type": "shell",
            "command": "find ./lib -name \"*.ab\" -print -exec amber check {} \\; && find ./src -name \"*.ab\" -print -exec amber check {} \\;",
            "problemMatcher": [ ]
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "find ./src -name \"*.ab\" -print -exec amber build {} \\;",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Test",
            "type": "shell",
            "command": "devcontainer features test --skip-autogenerated -f ${input:feature}",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Build"
        },
        {
            "label": "Generate docs",
            "type": "shell",
            "command": "(cd ./src && devcontainer features generate-docs -n \"NicoVIII/devcontainer-features\")",
            "problemMatcher": [ ]
        }
    ],
    "inputs": [
        {
            "id": "feature",
            "description": "A available feature inside of this repo",
            "options": [
                "amber",
                "gleam"
            ],
            "type": "pickString"
        }
    ]
}
