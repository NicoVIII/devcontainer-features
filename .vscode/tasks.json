{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Check",
            "type": "shell",
            "command": "set -e; for f in $(find ./lib ./src -name '*.ab'); do echo \"$f\"; amber check \"$f\"; done",
            "problemMatcher": []
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "set -e; for f in $(find ./src -name '*.ab'); do echo \"$f\"; amber build \"$f\"; done",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Test (One)",
            "type": "shell",
            "command": "devcontainer features test --skip-autogenerated -f ${input:feature}",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Build"
        },
        {
            "label": "Test (All)",
            "type": "shell",
            "command": "devcontainer features test --skip-autogenerated",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "dependsOn": "Build"
        },
        {
            "label": "Generate docs",
            "type": "shell",
            "command": "(cd ./src && devcontainer features generate-docs -n \"NicoVIII/devcontainer-features\")",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "feature",
            "description": "A available feature inside of this repo",
            "options": [
                "amber",
                "gleam",
                "just",
                "lefthook",
                "oxlint",
            ],
            "type": "pickString"
        }
    ]
}
