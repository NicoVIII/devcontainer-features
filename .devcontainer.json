{
    "image": "mcr.microsoft.com/devcontainers/base:2-noble",
    "features": {
        "ghcr.io/devcontainers/features/node:1": { },
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "disableIp6tables": true
        },
        "ghcr.io/NicoVIII/devcontainer-features/amber:0": {
            "version": "0.5.1-alpha"
        }
    },
    "postCreateCommand": "sudo update-alternatives --set iptables /usr/sbin/iptables-nft && npm install -g @devcontainers/cli",
    "customizations": {
        "vscode": {
            "extensions": [
                "editorconfig.editorconfig",
                "mads-hartmann.bash-ide-vscode"
            ]
        }
    }
}
